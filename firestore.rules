
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Funciones de utilidad básicas
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'I9Al3kS46rcTAbylTHgufUFke8b2' || 
        request.auth.token.email == 'info@datnova.io'
      );
    }

    // Validación de pertenencia a empresa (Multi-tenancy)
    // Se utiliza una ruta absoluta para asegurar consistencia en operaciones de listado
    function belongsToCompany(empresaId) {
      if (!isSignedIn()) return false;
      if (isSuperAdmin()) return true;
      
      let uid = request.auth.uid;
      let rootProfilePath = /databases/$(database)/documents/usuarios/$(uid);
      let companyUserPath = /databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(uid);
      
      // El acceso se concede si:
      // 1. El documento de usuario raíz apunta a esta empresa
      // 2. O si el usuario existe explícitamente en la subcolección de la empresa
      return (exists(rootProfilePath) && get(rootProfilePath).data.empresaId == empresaId) || 
             exists(companyUserPath);
    }

    // Reglas para el sistema de Invitaciones
    match /invitaciones/{tokenId} {
      allow read: if true;
      allow write: if isSuperAdmin() || (isSignedIn() && request.auth.token.email == resource.data.email);
    }

    // Reglas de Usuarios Raíz
    match /usuarios/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow write: if isSuperAdmin() || (isSignedIn() && request.auth.uid == uid);
    }

    // Estructura Multi-tenant Principal
    match /empresas/{empresaId} {
      allow read: if belongsToCompany(empresaId);
      allow write: if isSuperAdmin() || belongsToCompany(empresaId);

      // Regla recursiva para todas las subcolecciones (vehiculos, conductores, mantenimientos, inspecciones, etc.)
      match /{allSubcollections=**} {
        allow read, write: if belongsToCompany(empresaId);
      }
    }
    
    // Regla de seguridad global para el Superadmin
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
