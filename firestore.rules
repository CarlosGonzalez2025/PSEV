rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === FUNCIONES DE UTILIDAD ===
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'I9Al3kS46rcTAbylTHgufUFke8b2' ||
        request.auth.token.email == 'info@datnova.io'
      );
    }

    // Validación de pertenencia a empresa
    // Verifica AMBAS fuentes para máxima robustez
    function belongsToCompany(empresaId) {
      return isSignedIn() && (
        isSuperAdmin() ||
        // Verificar en la subcolección de la empresa (fuente primaria)
        exists(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid)) ||
        // Verificar en el perfil global del usuario (fuente secundaria)
        (exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.empresaId == empresaId)
      );
    }

    // Verificar si el usuario está activo en la empresa (usando el campo 'estado')
    function isActiveInCompany(empresaId) {
      return isSuperAdmin() || (
        belongsToCompany(empresaId) && (
          (exists(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid)).data.estado == 'Activo')
          ||
          (exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.estado == 'Activo')
        )
      );
    }

    // Verificar rol del usuario dentro de la empresa
    function hasRoleInCompany(empresaId, allowedRoles) {
      return belongsToCompany(empresaId) && (
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid)).data.rol in allowedRoles) ||
        (exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol in allowedRoles)
      );
    }

    // === INVITACIONES ===
    match /invitaciones/{tokenId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.token.email == resource.data.email || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // === USUARIOS RAÍZ (perfil global) ===
    match /usuarios/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // === EMPRESAS Y SUBCOLECCIONES ===
    match /empresas/{empresaId} {
      allow read: if isActiveInCompany(empresaId);
      allow create: if isSuperAdmin();
      allow update: if hasRoleInCompany(empresaId, ["Admin"]) || isSuperAdmin();
      allow delete: if isSuperAdmin();

      // Subcolección de usuarios de la empresa
      match /usuarios/{uid} {
        allow read: if isActiveInCompany(empresaId);
        allow create: if hasRoleInCompany(empresaId, ["Admin"]) || isSuperAdmin();
        allow update: if hasRoleInCompany(empresaId, ["Admin"]) || isSuperAdmin() ||
                        (isSignedIn() && request.auth.uid == uid);
        allow delete: if isSuperAdmin();
      }

      // Todas las demás subcolecciones operativas
      match /mantenimientos/{docId} {
        allow read: if isActiveInCompany(empresaId);
        allow write: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Auditor"]);
      }

      match /vehiculos/{docId} {
        allow read: if isActiveInCompany(empresaId);
        allow write: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]);
      }

      match /inspeccionesPreoperacionales/{docId} {
        allow read: if isActiveInCompany(empresaId);
        allow write: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Conductor"]);
      }

      // Catch-all para subcolecciones no listadas explícitamente
      match /{subcollection}/{docId} {
        allow read: if isActiveInCompany(empresaId);
        allow write: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]);
      }
    }

    // === AUDITORÍA ===
    match /_audit_log/{doc} {
      allow create: if isSignedIn();
      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }

    // === SUPERADMIN GLOBAL ===
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}