
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === FUNCIONES NÚCLEO DE SEGURIDAD ===
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'I9Al3kS46rcTAbylTHgufUFke8b2' ||
        request.auth.token.email == 'info@datnova.io'
      );
    }

    // Passport: Perfil global del usuario
    function getPassport() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    // Visa: Registro de membresía dentro de la empresa
    function hasValidVisa(empresaId) {
      return exists(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid)).data.estado == 'Activo';
    }

    // Lógica maestra de pertenencia
    function belongsToCompany(empresaId) {
      return isSignedIn() && (
        isSuperAdmin() || 
        (exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) && 
         getPassport().empresaId == empresaId && 
         getPassport().estado == 'Activo') ||
        hasValidVisa(empresaId)
      );
    }

    function hasRole(empresaId, allowedRoles) {
      return isSuperAdmin() || (belongsToCompany(empresaId) && getPassport().rol in allowedRoles);
    }

    // === REGLAS POR COLECCIÓN ===

    match /invitaciones/{tokenId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.token.email == resource.data.email || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    match /usuarios/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    match /empresas/{empresaId} {
      allow read: if belongsToCompany(empresaId);
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || (belongsToCompany(empresaId) && hasRole(empresaId, ['Admin', 'Lider_PESV']));
      allow delete: if isSuperAdmin();

      // Subcolección de usuarios (Membresía local)
      match /usuarios/{uid} {
        allow read: if belongsToCompany(empresaId);
        allow write: if isSuperAdmin() || (belongsToCompany(empresaId) && hasRole(empresaId, ['Admin']));
      }

      // Datos operativos (Vehículos, Mantenimientos, etc.)
      match /{subcollection}/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if belongsToCompany(empresaId) && 
                        hasRole(empresaId, ['Admin', 'Lider_PESV', 'Auditor', 'Conductor']) &&
                        request.resource.data.empresaId == empresaId;
        allow update: if belongsToCompany(empresaId) && 
                        hasRole(empresaId, ['Admin', 'Lider_PESV', 'Auditor', 'Conductor']);
        allow delete: if isSuperAdmin() || (belongsToCompany(empresaId) && hasRole(empresaId, ['Admin']));
      }
    }

    // Logs y Auditoría
    match /_audit_log/{doc} { allow create: if isSignedIn(); allow read: if isSuperAdmin(); }
    match /_audit_errors/{doc} { allow create: if isSignedIn(); allow read: if isSuperAdmin(); }

    // Backup Global
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
