
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.uid == 'I9Al3kS46rcTAbylTHgufUFke8b2';
    }

    function getUserData() {
      let userPath = /databases/$(database)/documents/usuarios/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data : null;
    }

    function belongsToCompany(empresaId) {
      if (!isSignedIn()) return false;
      if (isSuperAdmin()) return true;
      
      let userData = getUserData();
      // Verificamos que el usuario tenga un perfil y que su empresaId coincida
      // También verificamos si el usuario existe directamente en la subcolección de la empresa como respaldo
      return (userData != null && userData.empresaId == empresaId) || 
             exists(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid));
    }

    // Reglas para Invitaciones
    match /invitaciones/{tokenId} {
      allow read: if true; 
      // Permitir que el usuario invitado marque su invitación como usada
      allow update: if isSignedIn() && (resource.data.email == request.auth.token.email || isSuperAdmin());
      allow write: if isSuperAdmin();
    }

    // Reglas de Usuarios Raíz
    match /usuarios/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      // Permitir creación inicial por el propio usuario durante activación
      allow write: if isSuperAdmin() || (isSignedIn() && request.auth.uid == uid);
    }

    // Reglas Multi-tenant
    match /empresas/{empresaId} {
      allow read: if belongsToCompany(empresaId);
      allow write: if isSuperAdmin();

      match /{allSubcollections=**} {
        allow read: if belongsToCompany(empresaId);
        allow write: if belongsToCompany(empresaId);
      }
    }
    
    // Regla de escape para Superadmin (acceso total)
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
