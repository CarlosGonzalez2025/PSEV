rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === FUNCIONES DE UTILIDAD ===
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'I9Al3kS46rcTAbylTHgufUFke8b2' ||
        request.auth.token.email == 'info@datenova.io'
      );
    }

    function belongsToCompany(empresaId) {
      return isSignedIn() && (
        isSuperAdmin() ||
        exists(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid))
      );
    }

    function isActiveInCompany(empresaId) {
      return belongsToCompany(empresaId) && (
        isSuperAdmin() ||
        get(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid)).data.estado == 'Activo'
      );
    }

    function hasRoleInCompany(empresaId, roles) {
      return isActiveInCompany(empresaId) && (
        isSuperAdmin() ||
        get(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid)).data.rol in roles
      );
    }

    // ============================================================
    // SUPERADMIN GLOBAL — Evaluado primero, acceso total
    // ============================================================
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // === USUARIOS GLOBALES (Passport) ===
    match /usuarios/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if isSuperAdmin();
    }

    // === INVITACIONES ===
    match /invitaciones/{tokenId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSuperAdmin();
    }

    // === EMPRESAS Y SUBCOLECCIONES ===
    match /empresas/{empresaId} {
      allow read: if belongsToCompany(empresaId);
      allow create: if isSuperAdmin();
      allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]) || isSuperAdmin();
      allow delete: if isSuperAdmin();

      // Membresía de usuarios en la empresa (Visa)
      match /usuarios/{uid} {
        allow read: if belongsToCompany(empresaId);
        allow create: if (isSignedIn() && request.auth.uid == uid)
                      || hasRoleInCompany(empresaId, ["Admin", "RRHH"])
                      || isSuperAdmin();
        allow update: if hasRoleInCompany(empresaId, ["Admin", "RRHH"])
                      || isSuperAdmin()
                      || (isSignedIn() && request.auth.uid == uid);
        allow delete: if isSuperAdmin();
      }

      // Datos operativos — Vehículos
      // Gestor_Flota: acceso total | Lider_PESV: lectura + creación | Conductor: solo lectura
      match /vehiculos/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Gestor_Flota", "Conductor"]);
        allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Gestor_Flota"]);
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin", "Gestor_Flota"]);
      }

      // Datos operativos — Mantenimientos
      match /mantenimientos/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Gestor_Flota"]);
        allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Gestor_Flota"]);
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin", "Gestor_Flota"]);
      }

      // Datos operativos — Inspecciones Preoperacionales
      match /inspeccionesPreoperacionales/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Gestor_Flota", "Conductor"]);
        allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Gestor_Flota"]);
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin"]);
      }

      // Datos operativos — Inspecciones generales (colección inspecciones)
      match /inspecciones/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Gestor_Flota", "Conductor"]);
        allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Gestor_Flota"]);
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin"]);
      }

      // Datos operativos — Conductores / Talento Humano
      // RRHH: acceso total | Lider_PESV: lectura + escritura | Gestor_Flota: solo lectura
      match /conductores/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "RRHH"]);
        allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "RRHH"]);
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin", "RRHH"]);
      }

      // Datos operativos — Rutas
      match /rutas/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Gestor_Flota"]);
        allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Gestor_Flota"]);
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin"]);
      }

      // Datos operativos — Siniestros
      match /siniestros/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Conductor"]);
        allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]);
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin"]);
      }

      // Datos operativos — Capacitaciones / Formación
      // RRHH: acceso total (responsable de formación)
      match /capacitaciones/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "RRHH"]);
        allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "RRHH"]);
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin", "RRHH"]);
      }

      // Datos operativos — Indicadores
      match /indicadoresMedicion/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]);
        allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]);
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin"]);
      }

      // Datos operativos — Auditorías
      match /auditorias/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Auditor"]);
        allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Auditor"]);
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin"]);
      }

      // Datos operativos — Planes de Acción
      match /planesAccion/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]);
        allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]);
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin"]);
      }

      // Datos operativos — Combustible / Eficiencia energética
      // Gestor_Flota: acceso total | Conductor: registro
      match /combustible/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Gestor_Flota", "Conductor"]);
        allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Gestor_Flota"]);
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin", "Gestor_Flota"]);
      }

      // Datos operativos — Política PESV
      match /politica/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow write: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]) || isSuperAdmin();
      }

      // Datos operativos — Riesgos
      match /riesgos/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow write: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]) || isSuperAdmin();
      }

      // Datos operativos — Diagnóstico
      match /diagnostico/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow write: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]) || isSuperAdmin();
      }

      // Liderazgo PESV — Designación del Líder
      match /pesv_liderazgo/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow write: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]) || isSuperAdmin();
      }

      // Liderazgo PESV — Comité de Seguridad Vial
      match /pesv_comite_miembros/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]) || isSuperAdmin();
        allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]) || isSuperAdmin();
        allow delete: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]) || isSuperAdmin();
      }

      // Liderazgo PESV — Actas de Reuniones
      match /pesv_actas/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]) || isSuperAdmin();
        allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]) || isSuperAdmin();
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin"]);
      }

      // Liderazgo PESV — Presupuesto y Recursos
      match /pesv_recursos/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow write: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]) || isSuperAdmin();
      }
    }

    // === CONTRATISTAS Y GESTIÓN DEL CAMBIO (Paso 18) ===

    function isValidPortalToken(contratistaId, token) {
      return token != null && token == get(/databases/$(database)/documents/contratistas/$(contratistaId)).data.portalToken;
    }

    match /contratistas/{contratistaId} {
      allow read: if (isSignedIn() && belongsToCompany(resource.data.empresaId)) || (request.query.limit <= 1 && request.query.token != null);
      allow create: if hasRoleInCompany(request.resource.data.empresaId, ["Admin", "Lider_PESV", "Gestor_Flota"]);
      allow update: if hasRoleInCompany(resource.data.empresaId, ["Admin", "Lider_PESV", "Gestor_Flota"]);
      allow delete: if isSuperAdmin();
      allow get: if true;
    }

    match /conductoresContratistas/{conductorId} {
      allow read: if belongsToCompany(resource.data.empresaId);
      allow create: if (isSignedIn() && belongsToCompany(request.resource.data.empresaId)) ||
                      isValidPortalToken(request.resource.data.contratistaId, request.resource.data.portalToken);
      allow update: if (isSignedIn() && belongsToCompany(resource.data.empresaId)) ||
                      isValidPortalToken(resource.data.contratistaId, request.resource.data.portalToken);
      allow delete: if belongsToCompany(resource.data.empresaId);
    }

    match /vehiculosContratistas/{vehiculoId} {
      allow read: if belongsToCompany(resource.data.empresaId);
      allow create: if (isSignedIn() && belongsToCompany(request.resource.data.empresaId)) ||
                      isValidPortalToken(request.resource.data.contratistaId, request.resource.data.portalToken);
      allow update: if (isSignedIn() && belongsToCompany(resource.data.empresaId)) ||
                      isValidPortalToken(resource.data.contratistaId, request.resource.data.portalToken);
      allow delete: if belongsToCompany(resource.data.empresaId);
    }

    match /controlOperativoContratistas/{controlId} {
      allow read: if belongsToCompany(resource.data.empresaId);
      allow write: if hasRoleInCompany(request.resource.data.empresaId, ["Admin", "Lider_PESV", "Gestor_Flota"]);
    }

    match /gestionCambiosViales/{cambioId} {
      allow read: if belongsToCompany(resource.data.empresaId);
      allow write: if hasRoleInCompany(request.resource.data.empresaId, ["Admin", "Lider_PESV"]);
    }

    // === AUDITORÍA ===
    match /_audit_log/{doc} {
      allow create: if isSignedIn();
      allow read: if isSuperAdmin();
    }
    match /_audit_errors/{doc} {
      allow create: if isSignedIn();
      allow read: if isSuperAdmin();
    }
  }
}
