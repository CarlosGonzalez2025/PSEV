
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === FUNCIONES DE UTILIDAD ===
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'I9Al3kS46rcTAbylTHgufUFke8b2' ||
        request.auth.token.email == 'info@datnova.io'
      );
    }

    // El perfil global del usuario (/usuarios/{uid}) es la fuente de verdad absoluta
    function getUserProfile() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function profileExists() {
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    // Validación de pertenencia a empresa basada en el perfil raíz
    function belongsToCompany(empresaId) {
      return isSignedIn() && (
        isSuperAdmin() ||
        (profileExists() && getUserProfile().empresaId == empresaId)
      );
    }

    // El usuario debe estar activo en el sistema global
    function isActive() {
      return isSuperAdmin() || (
        profileExists() && getUserProfile().estado == 'Activo'
      );
    }

    // === INVITACIONES ===
    match /invitaciones/{tokenId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.token.email == resource.data.email || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // === PERFILES RAÍZ ===
    match /usuarios/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // === EMPRESAS Y SUS DATOS OPERATIVOS ===
    match /empresas/{empresaId} {
      allow read: if isSignedIn() && belongsToCompany(empresaId) && isActive();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || (belongsToCompany(empresaId) && getUserProfile().rol == 'Admin');
      allow delete: if isSuperAdmin();

      // Regla recursiva para todas las subcolecciones (vehiculos, mantenimientos, etc.)
      match /{allSubcollections=**} {
        allow read: if isSignedIn() && belongsToCompany(empresaId) && isActive();
        allow write: if isSignedIn() && belongsToCompany(empresaId) && isActive() &&
                     getUserProfile().rol in ['Admin', 'Lider_PESV', 'Auditor', 'Conductor'];
      }
    }

    // === LOGS Y DEPURE ===
    match /_audit_log/{doc} {
      allow create: if isSignedIn();
      allow read: if isSuperAdmin();
    }

    match /_audit_errors/{doc} {
      allow create: if isSignedIn();
      allow read: if isSuperAdmin();
    }

    // Respaldo Superadmin
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
