
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === FUNCIONES NÚCLEO DE SEGURIDAD ===
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'I9Al3kS46rcTAbylTHgufUFke8b2' ||
        request.auth.token.email == 'info@datnova.io'
      );
    }

    // Verifica si el usuario tiene el "Passport" (Perfil Raíz) correcto
    function hasValidPassport(empresaId) {
      let userDoc = get(/databases/$(database)/documents/usuarios/$(request.auth.uid));
      return userDoc != null && 
             userDoc.data.empresaId == empresaId && 
             userDoc.data.estado == 'Activo';
    }

    // Verifica si el usuario tiene la "Visa" (Registro de Membresía en la Empresa)
    function hasValidVisa(empresaId) {
      let membershipDoc = get(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid));
      return membershipDoc != null && 
             membershipDoc.data.estado == 'Activo';
    }

    // Lógica maestra de pertenencia: Superadmin OR Passport OR Visa
    function belongsToCompany(empresaId) {
      return isSignedIn() && (
        isSuperAdmin() || 
        hasValidPassport(empresaId) || 
        hasValidVisa(empresaId)
      );
    }

    function hasRole(empresaId, allowedRoles) {
      let userDoc = get(/databases/$(database)/documents/usuarios/$(request.auth.uid));
      return isSuperAdmin() || (userDoc != null && userDoc.data.rol in allowedRoles);
    }

    // === REGLAS POR COLECCIÓN ===

    match /invitaciones/{tokenId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.token.email == resource.data.email || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    match /usuarios/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    match /empresas/{empresaId} {
      // Un usuario puede leer los datos de su propia empresa
      allow read: if belongsToCompany(empresaId);
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || (belongsToCompany(empresaId) && hasRole(empresaId, ['Admin', 'Lider_PESV']));
      allow delete: if isSuperAdmin();

      // Subcolección de usuarios (Visa)
      match /usuarios/{uid} {
        allow read: if belongsToCompany(empresaId);
        allow write: if isSuperAdmin() || (belongsToCompany(empresaId) && hasRole(empresaId, ['Admin']));
      }

      // Colecciones operativas (Vehículos, Mantenimientos, Inspecciones, etc.)
      match /{subcollection}/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow write: if belongsToCompany(empresaId) && 
                     hasRole(empresaId, ['Admin', 'Lider_PESV', 'Auditor', 'Conductor']);
      }
    }

    // Auditoría
    match /_audit_log/{doc} { allow create: if isSignedIn(); allow read: if isSuperAdmin(); }
    match /_audit_errors/{doc} { allow create: if isSignedIn(); allow read: if isSuperAdmin(); }

    // Respaldo Global
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
