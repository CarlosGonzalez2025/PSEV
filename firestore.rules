rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ROADWISE 360 - SaaS SECURITY RULES
     * Superadmin UID: I9Al3kS46rcTAbylTHgufUFke8b2 (info@datnova.io)
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.uid == 'I9Al3kS46rcTAbylTHgufUFke8b2';
    }

    // El perfil del usuario define a qué empresa pertenece
    function getUserData() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function belongsToCompany(empresaId) {
      return isSignedIn() && (isSuperAdmin() || getUserData().empresaId == empresaId);
    }

    function hasRole(empresaId, roles) {
      return isSuperAdmin() || (belongsToCompany(empresaId) && getUserData().rol in roles);
    }

    // --- REGLAS DE USUARIOS (LOOKUP) ---
    match /usuarios/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow write: if isSuperAdmin(); // Solo el superadmin puede crear/editar perfiles raíz
    }

    // --- REGLAS DE EMPRESAS (MULTI-TENANCY) ---
    match /empresas/{empresaId} {
      allow read: if belongsToCompany(empresaId);
      allow write: if isSuperAdmin();

      match /{allSubcollections=**} {
        allow read: if belongsToCompany(empresaId);
        allow write: if belongsToCompany(empresaId); 
        // Nota: Para producción, se deben restringir roles específicos (ej. Conductor no edita Auditorías)
      }
    }
    
    // Acceso global para SuperAdmin
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}