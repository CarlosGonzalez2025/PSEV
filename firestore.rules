rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ROADWISE 360 - SECURITY RULES
     * Superadmin UID: I9Al3kS46rcTAbylTHgufUFke8b2 (info@datnova.io)
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.uid == 'I9Al3kS46rcTAbylTHgufUFke8b2';
    }

    function getProfile(empresaId) {
      return get(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid)).data;
    }

    function isMemberOf(empresaId) {
      return isSignedIn() && (isSuperAdmin() || exists(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid)));
    }

    function isAdmin(empresaId) {
      return isSuperAdmin() || (isMemberOf(empresaId) && (getProfile(empresaId).rol in ['Admin', 'Lider_PESV']));
    }

    // --- COLLECTION RULES ---

    match /empresas/{empresaId} {
      allow read: if isMemberOf(empresaId);
      allow write: if isSuperAdmin() || isAdmin(empresaId);

      match /{allSubcollections=**} {
        allow read: if isMemberOf(empresaId);
        allow write: if isMemberOf(empresaId); // Permiso amplio para prototipado rápido
      }
    }
    
    // Acceso global para SuperAdmin
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}