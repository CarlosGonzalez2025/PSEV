
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === FUNCIONES DE UTILIDAD ===
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'I9Al3kS46rcTAbylTHgufUFke8b2' ||
        request.auth.token.email == 'info@datnova.io'
      );
    }

    // Validación de pertenencia a empresa (Multi-tenancy)
    // Verifica el perfil raíz (/usuarios/{uid}) como fuente de verdad
    function belongsToCompany(empresaId) {
      return isSignedIn() && (
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.empresaId == empresaId)
      );
    }

    // Verifica que el usuario esté activo y tenga un rol válido
    function isActive() {
      return isSuperAdmin() || (
        exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.estado == 'Activo'
      );
    }

    function hasRole(allowedRoles) {
      return isSuperAdmin() || (
        exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol in allowedRoles
      );
    }

    // === INVITACIONES ===
    match /invitaciones/{tokenId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.token.email == resource.data.email || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // === USUARIOS RAÍZ ===
    match /usuarios/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // === EMPRESAS Y DATOS OPERATIVOS ===
    match /empresas/{empresaId} {
      allow read: if isSignedIn() && belongsToCompany(empresaId) && isActive();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || (belongsToCompany(empresaId) && hasRole(['Admin', 'Lider_PESV']));
      allow delete: if isSuperAdmin();

      // Regla para todas las subcolecciones operativas
      match /{allSubcollections=**} {
        allow read: if isSignedIn() && belongsToCompany(empresaId) && isActive();
        allow write: if isSignedIn() && belongsToCompany(empresaId) && isActive() &&
                     hasRole(['Admin', 'Lider_PESV', 'Auditor', 'Conductor']);
      }
    }

    // === AUDITORÍA ===
    match /_audit_log/{doc} {
      allow create: if isSignedIn();
      allow read: if isSuperAdmin();
    }

    match /_audit_errors/{doc} {
      allow create: if isSignedIn();
      allow read: if isSuperAdmin();
    }

    // Respaldo Superadmin
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
