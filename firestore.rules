
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === FUNCIONES DE UTILIDAD ===
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'I9Al3kS46rcTAbylTHgufUFke8b2' ||
        request.auth.token.email == 'info@datnova.io'
      );
    }

    // Perfil global (Passport)
    function getPassport() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    // Validación de pertenencia a empresa (Redundante para robustez)
    function belongsToCompany(empresaId) {
      return isSignedIn() && (
        isSuperAdmin() ||
        exists(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) && getPassport().empresaId == empresaId)
      );
    }

    function isActiveInCompany(empresaId) {
      return belongsToCompany(empresaId) && (
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) && getPassport().estado == 'Activo') ||
        (exists(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid)).data.estado == 'Activo')
      );
    }

    function hasRoleInCompany(empresaId, roles) {
      return isActiveInCompany(empresaId) && (
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) && getPassport().rol in roles)
      );
    }

    // === USUARIOS GLOBALES (Passport) ===
    match /usuarios/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // === INVITACIONES ===
    match /invitaciones/{tokenId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // Permitir actualización para marcar como usada durante el registro
      allow delete: if isSuperAdmin();
    }

    // === EMPRESAS Y SUBCOLECCIONES ===
    match /empresas/{empresaId} {
      allow read: if belongsToCompany(empresaId); // Permitir lectura básica para validación
      allow create: if isSuperAdmin();
      allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]) || isSuperAdmin();
      allow delete: if isSuperAdmin();

      // Membresía de usuarios en la empresa (Visa)
      match /usuarios/{uid} {
        allow read: if belongsToCompany(empresaId);
        // PERMITIR que el usuario cree su propia membresía durante el onboarding (Fase Crítica)
        allow create: if (isSignedIn() && request.auth.uid == uid) || hasRoleInCompany(empresaId, ["Admin"]) || isSuperAdmin();
        allow update: if hasRoleInCompany(empresaId, ["Admin"]) || isSuperAdmin() || (isSignedIn() && request.auth.uid == uid);
        allow delete: if isSuperAdmin();
      }

      // Datos operativos
      match /vehiculos/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if isActiveInCompany(empresaId) && hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Supervisor", "Conductor"]);
        allow update: if isActiveInCompany(empresaId) && hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Supervisor"]);
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin"]);
      }

      match /mantenimientos/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if isActiveInCompany(empresaId) && hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Supervisor"]);
        allow update: if isActiveInCompany(empresaId) && hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Supervisor"]);
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin"]);
      }

      match /inspeccionesPreoperacionales/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if isActiveInCompany(empresaId) && hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Conductor"]);
        allow update: if isActiveInCompany(empresaId) && hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]);
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin"]);
      }

      // Catch-all para subcolecciones nuevas
      match /{anySubcollection}/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow write: if hasRoleInCompany(empresaId, ["Admin"]) || isSuperAdmin();
      }
    }

    // === AUDITORÍA ===
    match /_audit_log/{doc} { allow create: if isSignedIn(); allow read: if isSuperAdmin(); }
    match /_audit_errors/{doc} { allow create: if isSignedIn(); allow read: if isSuperAdmin(); }

    // === SUPERADMIN GLOBAL ===
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
