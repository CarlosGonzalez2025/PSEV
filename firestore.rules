
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.uid == 'I9Al3kS46rcTAbylTHgufUFke8b2';
    }

    function getUserData() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function belongsToCompany(empresaId) {
      return isSignedIn() && (isSuperAdmin() || getUserData().empresaId == empresaId);
    }

    // Reglas para Invitaciones (Necesarias para el flujo de activación)
    match /invitaciones/{tokenId} {
      allow read: if true; // Permitir lectura pública para validación de token
      allow write: if isSuperAdmin();
    }

    // Reglas de Usuarios Raíz
    match /usuarios/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow write: if isSuperAdmin() || (isSignedIn() && request.auth.uid == uid && !exists(/databases/$(database)/documents/usuarios/$(uid)));
    }

    // Reglas Multi-tenant
    match /empresas/{empresaId} {
      allow read: if belongsToCompany(empresaId);
      allow write: if isSuperAdmin();

      match /{allSubcollections=**} {
        allow read: if belongsToCompany(empresaId);
        allow write: if belongsToCompany(empresaId);
      }
    }
    
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
