rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === FUNCIONES DE UTILIDAD ===
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'I9Al3kS46rcTAbylTHgufUFke8b2' ||
        request.auth.token.email == 'info@datenova.io'
      );
    }

    function belongsToCompany(empresaId) {
      return isSignedIn() && (
        isSuperAdmin() ||
        exists(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid))
      );
    }

    function isActiveInCompany(empresaId) {
      return belongsToCompany(empresaId) && (
        isSuperAdmin() ||
        get(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid)).data.estado == 'Activo'
      );
    }

    function hasRoleInCompany(empresaId, roles) {
      return isActiveInCompany(empresaId) && (
        isSuperAdmin() ||
        get(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid)).data.rol in roles
      );
    }

    // ============================================================
    // SUPERADMIN GLOBAL — Evaluado primero, acceso total
    // ============================================================
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // === USUARIOS GLOBALES (Passport) ===
    match /usuarios/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if isSuperAdmin();
    }

    // === INVITACIONES ===
    match /invitaciones/{tokenId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSuperAdmin();
    }

    // === EMPRESAS Y SUBCOLECCIONES ===
    match /empresas/{empresaId} {
      allow read: if belongsToCompany(empresaId);
      allow create: if isSuperAdmin();
      allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]) || isSuperAdmin();
      allow delete: if isSuperAdmin();

      // Membresía de usuarios en la empresa (Visa)
      match /usuarios/{uid} {
        allow read: if belongsToCompany(empresaId);
        allow create: if (isSignedIn() && request.auth.uid == uid) || hasRoleInCompany(empresaId, ["Admin"]) || isSuperAdmin();
        allow update: if hasRoleInCompany(empresaId, ["Admin"]) || isSuperAdmin() || (isSignedIn() && request.auth.uid == uid);
        allow delete: if isSuperAdmin();
      }

      // Datos operativos — Vehículos
      match /vehiculos/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Supervisor", "Conductor"]);
        allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Supervisor"]);
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin"]);
      }

      // Datos operativos — Mantenimientos
      match /mantenimientos/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Supervisor"]);
        allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Supervisor"]);
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin"]);
      }

      // Datos operativos — Inspecciones Preoperacionales
      match /inspeccionesPreoperacionales/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Conductor"]);
        allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]);
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin"]);
      }

      // Datos operativos — Conductores
      match /conductores/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]);
        allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]);
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin"]);
      }

      // Datos operativos — Rutas
      match /rutas/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]);
        allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]);
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin"]);
      }

      // Datos operativos — Siniestros
      match /siniestros/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Conductor"]);
        allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]);
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin"]);
      }

      // Datos operativos — Capacitaciones
      match /capacitaciones/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]);
        allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]);
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin"]);
      }

      // Datos operativos — Indicadores
      match /indicadoresMedicion/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]);
        allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]);
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin"]);
      }

      // Datos operativos — Auditorías
      match /auditorias/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Auditor"]);
        allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Auditor"]);
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin"]);
      }

      // Datos operativos — Planes de Acción
      match /planesAccion/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]);
        allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]);
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin"]);
      }

      // Datos operativos — Combustible
      match /combustible/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow create: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Conductor"]);
        allow update: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]);
        allow delete: if isSuperAdmin() || hasRoleInCompany(empresaId, ["Admin"]);
      }

      // Datos operativos — Política PESV
      match /politica/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow write: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]) || isSuperAdmin();
      }

      // Datos operativos — Riesgos
      match /riesgos/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow write: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]) || isSuperAdmin();
      }

      // Datos operativos — Diagnóstico
      match /diagnostico/{docId} {
        allow read: if belongsToCompany(empresaId);
        allow write: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV"]) || isSuperAdmin();
      }
    }

    // === AUDITORÍA ===
    match /_audit_log/{doc} {
      allow create: if isSignedIn();
      allow read: if isSuperAdmin();
    }
    match /_audit_errors/{doc} {
      allow create: if isSignedIn();
      allow read: if isSuperAdmin();
    }
  }
}
