rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === FUNCIONES DE UTILIDAD ===
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'I9Al3kS46rcTAbylTHgufUFke8b2' ||
        request.auth.token.email == 'info@datnova.io'
      );
    }

    // Validación de pertenencia a empresa basada en el perfil global
    function belongsToCompany(empresaId) {
      return isSignedIn() && (
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.empresaId == empresaId)
      );
    }

    // Verificar si el usuario está activo (usando el perfil global como fuente de verdad)
    function isActiveInCompany(empresaId) {
      return isSuperAdmin() || (
        belongsToCompany(empresaId) &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.estado == 'Activo'
      );
    }

    // Verificar rol del usuario
    function hasRoleInCompany(empresaId, allowedRoles) {
      return isSuperAdmin() || (
        isActiveInCompany(empresaId) &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol in allowedRoles
      );
    }

    // === INVITACIONES ===
    match /invitaciones/{tokenId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.token.email == resource.data.email || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // === USUARIOS RAÍZ (Perfil Global) ===
    match /usuarios/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // === EMPRESAS Y SUBCOLECCIONES ===
    match /empresas/{empresaId} {
      allow read: if isActiveInCompany(empresaId);
      allow create: if isSuperAdmin();
      allow update: if hasRoleInCompany(empresaId, ["Admin"]) || isSuperAdmin();
      allow delete: if isSuperAdmin();

      // Subcolecciones operativas
      match /{subcollection}/{docId} {
        allow read: if isActiveInCompany(empresaId);
        allow write: if hasRoleInCompany(empresaId, ["Admin", "Lider_PESV", "Auditor", "Conductor"]);
      }
    }

    // === AUDITORÍA ===
    match /_audit_log/{doc} {
      allow create: if isSignedIn();
      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }

    // === SUPERADMIN GLOBAL (Respaldo) ===
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}