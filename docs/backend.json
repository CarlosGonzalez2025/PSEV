
{
  "entities": {
    "EmpresaCliente": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "EmpresaCliente",
      "type": "object",
      "description": "Represents a client company or organization implementing the PESV.",
      "properties": {
        "id": { "type": "string" },
        "nit": { "type": "string" },
        "razonSocial": { "type": "string" },
        "misionalidad": { "type": "string" },
        "nivelPesv": { "type": "string" },
        "representanteLegalId": { "type": "string" },
        "liderPesvId": { "type": "string" },
        "fechaRegistro": { "type": "string", "format": "date-time" },
        "estado": { "type": "string" }
      },
      "required": ["id", "nit", "razonSocial", "misionalidad", "nivelPesv", "estado", "fechaRegistro"]
    },
    "Usuario": {
      "title": "Usuario",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "empresaId": { "type": "string" },
        "nombreCompleto": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "rol": { "type": "string" },
        "estado": { "type": "string" },
        "fechaCreacion": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "empresaId", "nombreCompleto", "email", "rol", "estado", "fechaCreacion"]
    },
    "Invitacion": {
      "title": "Invitación de Registro",
      "type": "object",
      "description": "Token temporal para que un administrador de empresa active su cuenta.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "empresaId": { "type": "string" },
        "rol": { "type": "string" },
        "token": { "type": "string" },
        "usada": { "type": "boolean" },
        "fechaExpiracion": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/empresas/{empresaId}",
        "definition": { "entityName": "EmpresaCliente", "description": "Client companies" }
      },
      {
        "path": "/usuarios/{usuarioId}",
        "definition": { "entityName": "Usuario", "description": "Global user lookup table for security rules" }
      },
      {
        "path": "/invitaciones/{invitacionId}",
        "definition": { "entityName": "Invitacion", "description": "Pending invitations for new tenants" }
      },
      {
        "path": "/empresas/{empresaId}/usuarios/{usuarioId}",
        "definition": { "entityName": "Usuario", "description": "Company-scoped users" }
      }
    ]
  }
}
