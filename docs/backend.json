{
  "entities": {
    "EmpresaCliente": {
      "title": "EmpresaCliente",
      "type": "object",
      "description": "Represents a client company or organization implementing the PESV.",
      "properties": {
        "id": { "type": "string" },
        "nit": { "type": "string" },
        "razonSocial": { "type": "string" },
        "misionalidad": { "type": "string" },
        "nivelPesv": { "type": "string" },
        "representanteLegalId": { "type": "string" },
        "liderPesvId": { "type": "string" },
        "fechaRegistro": { "type": "string", "format": "date-time" },
        "estado": { "type": "string" }
      },
      "required": ["id", "nit", "razonSocial", "misionalidad", "nivelPesv", "estado", "fechaRegistro"]
    },
    "Usuario": {
      "title": "Usuario",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "empresaId": { "type": "string" },
        "nombreCompleto": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "rol": { "type": "string" },
        "estado": { "type": "string" },
        "fechaCreacion": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "empresaId", "nombreCompleto", "email", "rol", "estado"]
    },
    "Vehiculo": {
      "title": "Vehículo (Hoja de Vida)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "empresaId": { "type": "string" },
        "placa": { "type": "string" },
        "vin": { "type": "string" },
        "numeroMotor": { "type": "string" },
        "marca": { "type": "string" },
        "modelo": { "type": "string" },
        "tipoVehiculo": { "type": "string" },
        "cilindraje": { "type": "string" },
        "carroceria": { "type": "string" },
        "propietario": { "type": "string" },
        "soatVencimiento": { "type": "string", "format": "date" },
        "rtmVencimiento": { "type": "string", "format": "date" },
        "polizaVencimiento": { "type": "string", "format": "date" },
        "kilometrajeActual": { "type": "number" },
        "kilometrajeMensualEstimado": { "type": "number" },
        "estadoOperativo": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/empresas/{empresaId}",
        "definition": { "entityName": "EmpresaCliente", "description": "Client companies" }
      },
      {
        "path": "/usuarios/{usuarioId}",
        "definition": { "entityName": "Usuario", "description": "Global user lookup table" }
      },
      {
        "path": "/empresas/{empresaId}/usuarios/{uid}",
        "definition": { "entityName": "Usuario", "description": "Company membership record" }
      },
      {
        "path": "/empresas/{empresaId}/vehiculos/{vehiculoId}",
        "definition": { "entityName": "Vehiculo", "description": "Company fleet" }
      },
      {
        "path": "/empresas/{empresaId}/mantenimientos/{mantenimientoId}",
        "definition": { "description": "Maintenance records" }
      },
      {
        "path": "/empresas/{empresaId}/inspeccionesPreoperacionales/{inspeccionId}",
        "definition": { "description": "Daily pre-operational inspections" }
      }
    ]
  }
}